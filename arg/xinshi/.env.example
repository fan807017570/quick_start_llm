# 复制为 .env 并填入真实值

# DeepSeek API Key（必填）
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 宿主机端口（默认值已与本机 Milvus 19530 / RAG 8765 区分开）
RAG_PORT=18765            # RAG 服务对外端口
MILVUS_EXPOSED_PORT=19531 # Milvus gRPC 端口（本机 19530 已占用）
MINIO_API_PORT=19000      # MinIO S3 API 端口
MINIO_UI_PORT=19001       # MinIO 控制台端口
